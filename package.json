{
  "name": "dbcode",
  "version": "0.1.0",
  "description": "CLI AI coding assistant for local/external LLMs",
  "type": "module",
  "bin": {
    "dbcode": "./bin/dbcode.mjs"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "chalk": "5.4.1",
    "commander": "13.1.0",
    "ink": "5.1.0",
    "js-tiktoken": "1.0.19",
    "marked": "15.0.7",
    "marked-terminal": "7.3.0",
    "mitt": "3.0.1",
    "openai": "4.85.4",
    "pino": "9.6.0",
    "react": "18.3.1",
    "shiki": "3.2.1",
    "zod": "3.24.2",
    "zod-to-json-schema": "3.24.5"
  },
  "devDependencies": {
    "@eslint/js": "9.22.0",
    "@types/node": "22.13.10",
    "@types/react": "18.3.18",
    "eslint": "9.22.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "madge": "8.0.0",
    "prettier": "3.5.3",
    "tsup": "8.4.0",
    "typescript": "5.8.2",
    "typescript-eslint": "8.26.0",
    "vitest": "3.0.8"
  },
  "keywords": [
    "ai",
    "coding-assistant",
    "cli",
    "llm"
  ],
  "license": "MIT"
}

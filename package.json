{
  "name": "dhelix",
  "version": "0.2.0",
  "description": "CLI AI coding assistant for local/external LLMs",
  "type": "module",
  "bin": {
    "dhelix": "./bin/dhelix.mjs"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run lint && npm run test:coverage && npm run build",
    "prepublishOnly": "npm run ci",
    "check": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "chalk": "5.4.1",
    "commander": "13.1.0",
    "dotenv": "^17.3.1",
    "fast-glob": "^3.3.3",
    "ink": "5.1.0",
    "js-tiktoken": "1.0.19",
    "marked": "15.0.7",
    "marked-terminal": "7.3.0",
    "mitt": "3.0.1",
    "openai": "^6.27.0",
    "pdf-parse": "^2.4.5",
    "pino": "9.6.0",
    "react": "18.3.1",
    "shiki": "3.2.1",
    "tree-sitter-wasms": "^0.1.13",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "web-tree-sitter": "^0.26.7",
    "zod": "3.24.2",
    "zod-to-json-schema": "3.24.5"
  },
  "devDependencies": {
    "@eslint/js": "9.22.0",
    "@types/node": "22.13.10",
    "@types/react": "18.3.18",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "9.22.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "madge": "8.0.0",
    "prettier": "3.5.3",
    "tsup": "8.4.0",
    "typescript": "5.8.2",
    "typescript-eslint": "8.26.0",
    "vitest": "3.0.8"
  },
  "keywords": [
    "ai",
    "coding-assistant",
    "cli",
    "llm"
  ],
  "license": "MIT"
}
